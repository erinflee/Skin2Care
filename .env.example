# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real keys.

# --- Groq (required) -------------------------------------------------
# LLM API key that powers the recommendations. Get one at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# --- AWS S3 (optional) -----------------------------------------------
# Where the FAISS index is stored. Leave these unset to run fully local
# (the app falls back to the committed faiss_index/ folder).
# Credentials should belong to a read-only IAM user, not the root account.
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
